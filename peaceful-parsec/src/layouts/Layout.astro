---
import '../styles/theme.css';
import ogImage from '../assets/og.png';

interface Props {
	title?: string;
	description?: string;
	lang?: string;
}

const {
	title = 'Vivallo | Full Stack Engineer',
	description = 'Portfolio and services for modern web product development with Astro and Svelte.',
	lang = 'en'
} = Astro.props;

const ogUrl = new URL(ogImage.src, Astro.site ?? 'https://vivallo.xyz').href;
---

<!doctype html>
<html lang={lang} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#332d4a" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
		<title>{title}</title>
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogUrl} />
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogUrl} />
		<script is:inline defer src="https://stats.lambdahq.co/script.js" data-website-id="dc449e4f-1470-4ca2-90da-a64c90693f47"></script>
		<slot name="head" />
	</head>
	<body>
		<div class="site-root">
			<slot />
		</div>
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		line-height: 1.5;
		text-rendering: optimizeLegibility;
		-webkit-font-smoothing: antialiased;
	}

	.site-root {
		min-height: 100vh;
	}
</style>

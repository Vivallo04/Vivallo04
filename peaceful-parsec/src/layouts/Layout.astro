---
import '../styles/theme.css';

interface Props {
	title?: string;
	description?: string;
	lang?: string;
}

const {
	title = 'Vivallo | Full Stack Engineer',
	description = 'Portfolio and services for modern web product development with Astro and Svelte.',
	lang = 'en'
} = Astro.props;
---

<!doctype html>
<html lang={lang} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#111722" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
		<slot name="head" />
	</head>
	<body>
		<div class="site-root">
			<slot />
		</div>
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		line-height: 1.5;
		text-rendering: optimizeLegibility;
		-webkit-font-smoothing: antialiased;
	}

	.site-root {
		min-height: 100vh;
	}
</style>

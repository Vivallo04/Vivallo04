---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const PRODUCT_ID  = "12db69db-b48a-422d-b4a5-d55207f43e26";
const checkoutUrl = `/api/checkout?products=${PRODUCT_ID}`;
const purchased   = Astro.url.searchParams.get('purchased') === '1';
---

<Layout
  title="698 Skills para Claude Code — $12 pago único"
  description="El pack más completo de skills para Claude Code. 698 skills handpicked para marketing, ventas, contenido, finanzas, legal y estrategia. $12, una sola vez."
>

{purchased && (
  <div class="fixed top-0 inset-x-0 z-50 bg-emerald-500 text-white text-sm font-medium text-center py-3 px-4">
    ✓ ¡Pago completado! Revisa tu email para el enlace de descarga.
  </div>
)}

<div class="min-h-screen text-foreground" style="font-family: var(--font-sans);">

  <!-- ── NAV ── -->
  <nav class="border-b border-border px-5 py-4 flex items-center justify-between max-w-5xl mx-auto">
    <a href="/" class="text-sm text-muted-foreground hover:text-foreground transition-colors">← vivallo.xyz</a>
    <a href={checkoutUrl} class="text-sm font-semibold bg-primary text-primary-foreground px-4 py-2 rounded-lg hover:opacity-90 transition-opacity">
      Conseguir el pack — $12
    </a>
  </nav>

  <!-- ── HERO ── -->
  <section class="max-w-4xl mx-auto px-5 pt-16 pb-12 text-center">
    <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5 text-xs font-semibold text-primary uppercase tracking-wide mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
      698 skills · Más que cualquier otro pack del mercado
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-[1.1] mb-6">
      Convierte Claude Code en<br>
      <span class="text-primary">tu equipo completo</span>
    </h1>

    <p class="text-lg text-muted-foreground max-w-2xl mx-auto mb-8 leading-relaxed">
      698 skills handpicked para founders, operadores y solopreneurs.
      Marketing, ventas, contenido, finanzas, legal, estrategia e IA —
      todo listo para usar desde el primer día.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-6">
      <a href={checkoutUrl}
         class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground font-bold text-base px-8 py-4 rounded-xl hover:opacity-90 transition-opacity shadow-lg">
        Conseguir el pack completo
        <span class="bg-primary-foreground/20 text-primary-foreground text-sm font-bold px-2.5 py-0.5 rounded-md">$12</span>
      </a>
      <a href="/skills"
         class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-border text-foreground font-medium text-base px-6 py-4 rounded-xl hover:bg-card transition-colors">
        Ver los 698 skills →
      </a>
    </div>

    <div class="flex items-center justify-center gap-6 text-xs text-muted-foreground">
      <span class="flex items-center gap-1.5">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="text-emerald-400"><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zm3.54 4.96L6.75 9.75 4.46 7.46l-1.42 1.42 3.71 3.7 6.21-6.2-1.42-1.42z"/></svg>
        Pago único · sin suscripción
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="text-emerald-400"><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zm3.54 4.96L6.75 9.75 4.46 7.46l-1.42 1.42 3.71 3.7 6.21-6.2-1.42-1.42z"/></svg>
        Descarga instantánea
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="text-emerald-400"><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zm3.54 4.96L6.75 9.75 4.46 7.46l-1.42 1.42 3.71 3.7 6.21-6.2-1.42-1.42z"/></svg>
        Garantía 7 días
      </span>
    </div>
  </section>

  <!-- ── STATS BAR ── -->
  <section class="border-y border-border bg-card">
    <div class="max-w-4xl mx-auto px-5 py-8 grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
      {[
        { num: "698",  label: "Skills incluidos" },
        { num: "8",    label: "Categorías de negocio" },
        { num: "$12",  label: "Pago único, para siempre" },
        { num: "2min", label: "Tiempo de instalación" },
      ].map(s => (
        <div>
          <div class="text-2xl sm:text-3xl font-bold text-primary">{s.num}</div>
          <div class="text-xs text-muted-foreground mt-1">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── HOW TO INSTALL ── -->
  <section class="max-w-4xl mx-auto px-5 py-16">
    <div class="text-center mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Instalación en 3 pasos</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-foreground">Listo en menos de 2 minutos</h2>
    </div>

    <div class="grid sm:grid-cols-3 gap-6">
      <!-- Step 1 -->
      <div class="rounded-xl border border-border bg-card p-6">
        <div class="w-8 h-8 rounded-full bg-primary/15 text-primary text-sm font-bold flex items-center justify-center mb-4">1</div>
        <h3 class="font-semibold text-foreground mb-2">Descarga y descomprime</h3>
        <p class="text-sm text-muted-foreground mb-4">Recibirás un ZIP con los 698 skills organizados por categoría.</p>
        <div class="bg-background rounded-lg p-3 font-mono text-xs text-muted-foreground border border-border">
          claude-agents-pack.zip<br>
          └── skills/<br>
          &nbsp;&nbsp;&nbsp;├── marketing/<br>
          &nbsp;&nbsp;&nbsp;├── content-writing/<br>
          &nbsp;&nbsp;&nbsp;└── ...
        </div>
      </div>

      <!-- Step 2 -->
      <div class="rounded-xl border border-border bg-card p-6">
        <div class="w-8 h-8 rounded-full bg-primary/15 text-primary text-sm font-bold flex items-center justify-center mb-4">2</div>
        <h3 class="font-semibold text-foreground mb-2">Copia a tu directorio de skills</h3>
        <p class="text-sm text-muted-foreground mb-4">Mueve las carpetas al directorio de skills de Claude Code.</p>
        <div class="bg-background rounded-lg p-3 font-mono text-xs border border-border space-y-1">
          <p class="text-muted-foreground"># Global (todos los proyectos)</p>
          <p class="text-primary">cp -r skills/* ~/.claude/skills/</p>
          <p class="text-muted-foreground mt-2"># O por proyecto</p>
          <p class="text-primary">cp -r skills/* .claude/skills/</p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="rounded-xl border border-border bg-card p-6">
        <div class="w-8 h-8 rounded-full bg-primary/15 text-primary text-sm font-bold flex items-center justify-center mb-4">3</div>
        <h3 class="font-semibold text-foreground mb-2">Usa el skill que necesites</h3>
        <p class="text-sm text-muted-foreground mb-4">Claude detecta el skill automáticamente o úsalo directamente.</p>
        <div class="bg-background rounded-lg p-3 font-mono text-xs border border-border space-y-1">
          <p class="text-muted-foreground"># Invocación directa</p>
          <p class="text-primary">/email-sequence</p>
          <p class="text-muted-foreground mt-2"># O simplemente describe</p>
          <p class="text-primary">"crea una secuencia de<br>emails para mi producto"</p>
        </div>
      </div>
    </div>

    <p class="text-center text-sm text-muted-foreground mt-6">
      También incluimos <strong class="text-foreground">guide.html</strong> — un browser interactivo para explorar los 698 skills sin abrir ningún archivo.
    </p>
  </section>

  <!-- ── WHAT'S INCLUDED ── -->
  <section class="border-t border-border bg-card">
    <div class="max-w-4xl mx-auto px-5 py-16">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">698 skills en 8 categorías</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-foreground">Todo lo que necesitas para tu negocio</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {[
          { icon: "📈", cat: "Marketing y Crecimiento",   n: 30, examples: "Email sequences, SEO, Google Ads, leads, brand" },
          { icon: "✍️",  cat: "Creación de Contenido",    n: 31, examples: "Copywriting, blog, LinkedIn, YouTube, viral hooks" },
          { icon: "💼", cat: "Ventas y CRM",              n: 17, examples: "Outreach, propuestas, upsells, customer success" },
          { icon: "💰", cat: "Finanzas y Precios",        n: 14, examples: "Modelos financieros, facturas, análisis, pagos" },
          { icon: "⚖️",  cat: "Legal y Contratos",        n:  9, examples: "Contratos, GDPR, compliance, análisis de riesgos" },
          { icon: "⚙️",  cat: "Operaciones y SOPs",       n: 10, examples: "SOPs, retención, churn, actas de reuniones" },
          { icon: "🧭", cat: "Estrategia y Planificación",n: 30, examples: "OKRs, market research, producto, competidores" },
          { icon: "🤖", cat: "IA para Negocios",          n:  7, examples: "Prompt engineering, agentes, automatización" },
        ].map(c => (
          <div class="rounded-xl border border-border bg-background p-4 hover:border-primary/40 transition-colors">
            <div class="text-2xl mb-2">{c.icon}</div>
            <div class="font-semibold text-sm text-foreground mb-1">{c.cat}</div>
            <div class="text-xs font-bold text-primary mb-2">{c.n} skills</div>
            <div class="text-xs text-muted-foreground leading-relaxed">{c.examples}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── WHO IT'S FOR ── -->
  <section class="max-w-4xl mx-auto px-5 py-16">
    <div class="text-center mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">¿Para quién es?</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-foreground">Si usas Claude Code para trabajar, esto es para ti</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        { icon: "🚀", who: "Founders y Startups",      desc: "Lanza más rápido sin contratar un equipo completo. Cubre marketing, ops y finanzas desde el día uno." },
        { icon: "🧑‍💻", who: "Solopreneurs",            desc: "Sé tu propio CMO, CFO y COO. Delega las tareas repetitivas a Claude con un solo comando." },
        { icon: "📊", who: "Consultores",               desc: "Entrega trabajo de cliente en minutos. Propuestas, análisis y estrategias listas para presentar." },
        { icon: "✏️",  who: "Creadores de Contenido",  desc: "Automatiza el calendario editorial completo. Ideas, drafts, adaptaciones y distribución." },
        { icon: "💸", who: "Freelancers",               desc: "Acepta más proyectos sin sacrificar calidad. Los skills hacen el trabajo pesado por ti." },
        { icon: "🏢", who: "Equipos pequeños",          desc: "Compite con empresas 10 veces más grandes. Un equipo de 3 con el output de 30." },
      ].map(p => (
        <div class="rounded-xl border border-border bg-card p-5">
          <div class="text-2xl mb-3">{p.icon}</div>
          <div class="font-semibold text-foreground mb-1.5">{p.who}</div>
          <div class="text-sm text-muted-foreground leading-relaxed">{p.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── WHAT SKILLS ARE ── -->
  <section class="border-t border-border bg-card">
    <div class="max-w-3xl mx-auto px-5 py-16">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">¿Qué son los Claude Skills?</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-foreground">No son prompts. Son sistemas expertos.</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-6 mb-10">
        <div class="rounded-xl border border-red-500/20 bg-red-500/5 p-5">
          <p class="text-sm font-semibold text-red-400 mb-3">❌ Un prompt normal</p>
          <p class="text-sm text-muted-foreground italic">"Escríbeme un email de ventas para mi producto."</p>
          <p class="text-xs text-muted-foreground mt-3">→ Respuesta genérica. Tienes que reescribirla tú.</p>
        </div>
        <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/5 p-5">
          <p class="text-sm font-semibold text-emerald-400 mb-3">✅ Con el skill <code class="text-xs bg-emerald-500/10 px-1 py-0.5 rounded">/email-sequence</code></p>
          <p class="text-sm text-muted-foreground italic">Claude te pregunta el producto, audiencia y objetivo → genera una secuencia de 5 emails con asuntos, CTAs y timing optimizados.</p>
          <p class="text-xs text-muted-foreground mt-3">→ Listo para enviar.</p>
        </div>
      </div>

      <div class="grid sm:grid-cols-3 gap-4 text-center">
        {[
          { icon: "🧠", title: "Frameworks expertos",  desc: "Cada skill contiene metodologías probadas, no respuestas genéricas." },
          { icon: "❓", title: "Recopilación inteligente", desc: "Claude pregunta lo que necesita antes de generar. Outputs personalizados." },
          { icon: "📋", title: "Output estructurado",  desc: "Sabes exactamente qué vas a recibir: formato, secciones y nivel de detalle." },
        ].map(f => (
          <div class="p-4">
            <div class="text-2xl mb-2">{f.icon}</div>
            <div class="text-sm font-semibold text-foreground mb-1">{f.title}</div>
            <div class="text-xs text-muted-foreground">{f.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PRICE ANCHOR ── -->
  <section class="max-w-3xl mx-auto px-5 py-16">
    <div class="text-center mb-8">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Precio</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-foreground">Menos que una consultoría de una hora</h2>
    </div>

    <div class="rounded-2xl border border-primary/30 bg-card overflow-hidden">
      <!-- Value table -->
      <div class="p-6 space-y-3">
        {[
          { cat: "Marketing y Crecimiento (30 skills)",    val: "$97" },
          { cat: "Contenido y Copywriting (31 skills)",    val: "$89" },
          { cat: "Ventas y CRM (17 skills)",               val: "$79" },
          { cat: "Finanzas y Precios (14 skills)",         val: "$69" },
          { cat: "Legal y Contratos (9 skills)",           val: "$59" },
          { cat: "Operaciones y SOPs (10 skills)",         val: "$69" },
          { cat: "Estrategia y Planificación (30 skills)", val: "$97" },
          { cat: "IA para Negocios (7 skills)",            val: "$49" },
        ].map(r => (
          <div class="flex items-center justify-between text-sm">
            <span class="text-muted-foreground">{r.cat}</span>
            <span class="font-medium text-foreground line-through opacity-50">{r.val}</span>
          </div>
        ))}

        <div class="border-t border-border pt-3 flex items-center justify-between">
          <span class="text-sm text-muted-foreground">Valor total</span>
          <span class="text-sm font-bold text-foreground line-through opacity-50">$608</span>
        </div>
      </div>

      <!-- CTA block -->
      <div class="bg-primary/10 border-t border-primary/20 p-6 text-center">
        <div class="flex items-baseline justify-center gap-3 mb-1">
          <span class="text-5xl font-bold text-foreground">$12</span>
          <span class="text-muted-foreground">pago único</span>
        </div>
        <p class="text-xs text-muted-foreground mb-5">acceso de por vida · sin cuotas mensuales · sin límites de uso</p>
        <a href={checkoutUrl}
           class="inline-flex items-center justify-center gap-2 w-full max-w-sm bg-primary text-primary-foreground font-bold text-base px-8 py-4 rounded-xl hover:opacity-90 transition-opacity">
          Conseguir los 698 skills — $12
        </a>
        <p class="text-xs text-muted-foreground mt-3">
          🔒 Pago seguro vía Polar · 7 días de garantía sin preguntas
        </p>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="border-t border-border bg-card">
    <div class="max-w-3xl mx-auto px-5 py-16">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-foreground">Preguntas frecuentes</h2>
      </div>

      <div class="space-y-4" id="faq">
        {[
          {
            q: "¿Funciona con Claude.ai o solo con Claude Code?",
            a: "Los skills están optimizados para Claude Code (el CLI oficial de Anthropic), donde puedes invocarlos directamente con /nombre-skill. Muchos también funcionan copiando el contenido del SKILL.md en el system prompt de Claude.ai."
          },
          {
            q: "¿Necesito saber programar para instalarlos?",
            a: "No. La instalación es copiar una carpeta a ~/.claude/skills/. Si sabes usar una terminal básica, tardas menos de 2 minutos. Incluimos guía paso a paso con los comandos exactos."
          },
          {
            q: "¿Cuántos skills puedo usar a la vez?",
            a: "Todos los que quieras. Los skills se cargan bajo demanda — Claude solo activa el que invocas, sin sobrecargar el contexto."
          },
          {
            q: "¿Qué pasa si no me sirven?",
            a: "Tienes 7 días para pedir el reembolso completo, sin preguntas. Escríbenos y lo procesamos el mismo día."
          },
          {
            q: "¿Cómo recibo el archivo?",
            a: "Tras el pago, Polar te envía un email con el enlace de descarga al instante. Es un ZIP de ~3MB con todo organizado por categoría."
          },
        ].map((item, i) => (
          <details class="rounded-xl border border-border bg-background group" name="faq">
            <summary class="flex items-center justify-between cursor-pointer px-5 py-4 font-medium text-sm text-foreground list-none">
              {item.q}
              <svg class="w-4 h-4 text-muted-foreground shrink-0 transition-transform group-open:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M8 10.6L2.4 5l1.2-1.2L8 8.2l4.4-4.4L13.6 5z"/></svg>
            </summary>
            <div class="px-5 pb-4 text-sm text-muted-foreground leading-relaxed border-t border-border pt-4">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ── -->
  <section class="max-w-3xl mx-auto px-5 py-16 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-foreground mb-4">
      Tu negocio a velocidad de IA
    </h2>
    <p class="text-muted-foreground mb-8 max-w-xl mx-auto">
      698 skills. 8 categorías. Un pago. Empieza a usarlos hoy —
      si no ahorras tiempo en la primera semana, te devolvemos el dinero.
    </p>
    <a href={checkoutUrl}
       class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground font-bold text-base px-10 py-4 rounded-xl hover:opacity-90 transition-opacity shadow-lg">
      Conseguir el pack completo — $12
    </a>
    <p class="text-xs text-muted-foreground mt-4">
      Pago único · Garantía 7 días · Descarga instantánea
    </p>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="border-t border-border text-center py-6 text-xs text-muted-foreground">
    <a href="/" class="hover:text-foreground transition-colors">vivallo.xyz</a>
    <span class="mx-2">·</span>
    <span>© 2026</span>
  </footer>

</div>

<style>
  details summary::-webkit-details-marker { display: none; }
</style>

</Layout>

<script>
  const io = new IntersectionObserver(
    es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>
<script is:inline>
  // PostHog: track checkout_initiated on CTA clicks
  document.querySelectorAll('a[href*="/api/checkout"]').forEach(function(link) {
    link.addEventListener('click', function() {
      if (window.posthog) {
        posthog.capture('checkout_initiated', {
          product: '698 skills para Claude Code',
          price: 12,
          currency: 'USD',
          cta_text: link.textContent.trim()
        });
      }
    });
  });

  // PostHog: track faq_expanded when a <details> is opened
  document.querySelectorAll('.faqs details').forEach(function(details) {
    details.addEventListener('toggle', function() {
      if (details.open && window.posthog) {
        var summary = details.querySelector('summary');
        posthog.capture('faq_expanded', {
          question: summary ? summary.textContent.replace('+', '').trim() : ''
        });
      }
    });
  });
</script>


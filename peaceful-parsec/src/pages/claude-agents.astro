---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import '../styles/claude-theme.css';

const PRODUCT_ID  = "75f282c8-a321-4c68-8af4-56c801fb4afa";
const checkoutUrl = `/api/checkout?products=${PRODUCT_ID}`;
const purchased   = Astro.url.searchParams.get('purchased') === '1';
---

<Layout
  title="698 Skills para Claude Code — $12 pago único"
  description="698 skills handpicked para Claude Code. Marketing, ventas, contenido, finanzas y estrategia. $12 pago único, descarga instantánea."
  theme="light"
  htmlClass="claude-theme"
>

<style>
  /* All colors use the site's existing CSS variables from theme.css */
  .page { min-height: 100vh; background: var(--background); color: var(--foreground); font-family: var(--font-sans, Montserrat, sans-serif); }

  /* ── Success ── */
  .success { background: oklch(0.95 0.08 142); border-bottom: 1px solid oklch(0.75 0.12 142); color: oklch(0.3 0.12 142); font-size: 14px; font-weight: 500; padding: 12px 32px; text-align: center; }

  /* ── Nav ── */
  .nav {
    position: sticky; top: 0; z-index: 100;
    background: color-mix(in oklch, var(--background) 90%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 13px 32px;
    display: flex; align-items: center; justify-content: flex-end;
  }
  .nav-back { font-size: 13px; color: var(--muted-foreground); text-decoration: none; display: flex; align-items: center; gap: 6px; transition: color 0.2s; }
  .nav-back:hover { color: var(--foreground); }
  .nav-right { display: flex; align-items: center; gap: 16px; }
  .nav-label { font-size: 12px; color: var(--muted-foreground); font-family: var(--font-mono, 'Fira Code', monospace); }
  .nav-label strong { color: var(--primary); }
  .btn-nav {
    font-size: 13px; font-weight: 600;
    background: var(--primary); color: var(--primary-foreground);
    padding: 8px 20px; border-radius: var(--radius, 0.35rem); text-decoration: none;
    transition: opacity 0.2s, transform 0.15s;
  }
  .btn-nav:hover { opacity: 0.88; transform: translateY(-1px); }

  /* ── Hero ── */
  .hero { max-width: 820px; margin: 0 auto; padding: 80px 32px 64px; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: color-mix(in oklch, var(--primary) 10%, transparent);
    border: 1px solid color-mix(in oklch, var(--primary) 25%, transparent);
    border-radius: 100px; padding: 5px 14px; margin-bottom: 32px;
    font-size: 11px; font-weight: 600; color: var(--primary);
    font-family: var(--font-mono, monospace); letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .hero-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--primary); animation: blink 2s ease-in-out infinite; }
  @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

  .hero-h {
    font-size: clamp(40px, 6vw, 72px); font-weight: 700; line-height: 1.05;
    letter-spacing: -0.025em; color: var(--foreground); margin-bottom: 24px;
  }
  .hero-h em { font-style: normal; color: var(--primary); }

  .hero-sub {
    font-size: 17px; line-height: 1.7; color: var(--muted-foreground);
    max-width: 520px; margin-bottom: 40px; font-weight: 400;
  }

  .hero-actions { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 32px; }
  .btn-primary {
    font-size: 15px; font-weight: 700;
    background: var(--primary); color: var(--primary-foreground);
    padding: 14px 32px; border-radius: var(--radius); text-decoration: none;
    transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: var(--shadow-lg);
    display: inline-flex; align-items: center; gap: 10px;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-2px); box-shadow: var(--shadow-xl); }
  .price-tag { background: rgba(255,255,255,0.2); padding: 3px 10px; border-radius: 4px; font-size: 13px; font-family: var(--font-mono, monospace); }

  .hero-trust { display: flex; gap: 20px; flex-wrap: wrap; }
  .trust-item { font-size: 12px; color: var(--muted-foreground); display: flex; align-items: center; gap: 5px; font-family: var(--font-mono, monospace); }
  .trust-item .check { color: oklch(0.6 0.15 142); }

  /* ── Divider ── */
  hr.div { border: none; border-top: 1px solid var(--border); margin: 0 32px; }

  /* ── Proof bar ── */
  .proof-bar {
    border-bottom: 1px solid var(--border); background: var(--card);
    padding: 14px 32px;
    display: flex; align-items: center; justify-content: center;
    gap: 32px; flex-wrap: wrap;
  }
  .proof-item { font-size: 12px; color: var(--muted-foreground); font-family: var(--font-mono, monospace); display: flex; align-items: center; gap: 6px; }
  .proof-item strong { color: var(--foreground); font-weight: 600; }
  .proof-sep { color: var(--border); }

  /* ── Sections ── */
  .section { max-width: 820px; margin: 0 auto; padding: 72px 32px; }
  .section-alt { background: var(--card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .section-alt .inner { max-width: 820px; margin: 0 auto; padding: 72px 32px; }

  .eyebrow { font-size: 11px; font-weight: 600; color: var(--primary); letter-spacing: 0.12em; text-transform: uppercase; font-family: var(--font-mono, monospace); margin-bottom: 12px; }
  .section-h { font-size: clamp(26px, 3.5vw, 38px); font-weight: 700; line-height: 1.1; letter-spacing: -0.02em; color: var(--foreground); margin-bottom: 48px; }
  .section-h span { color: var(--primary); }

  /* ── Skill cards ── */
  .skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 10px; }
  .skill-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: calc(var(--radius) + 4px); padding: 18px 20px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .skill-card:hover { border-color: color-mix(in oklch, var(--primary) 50%, transparent); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .skill-cmd { font-family: var(--font-mono, monospace); font-size: 12px; color: var(--primary); margin-bottom: 7px; font-weight: 500; }
  .skill-desc { font-size: 12.5px; color: var(--muted-foreground); line-height: 1.55; margin-bottom: 10px; }
  .skill-cat { display: inline-block; font-size: 10px; font-weight: 600; font-family: var(--font-mono, monospace); color: var(--muted-foreground); background: var(--muted); border-radius: 3px; padding: 2px 7px; letter-spacing: 0.04em; }

  /* ── Steps ── */
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .step { background: var(--background); border: 1px solid var(--border); border-radius: calc(var(--radius) + 4px); padding: 28px; }
  .step-num { font-size: 40px; font-weight: 700; color: var(--border); line-height: 1; margin-bottom: 16px; letter-spacing: -0.03em; }
  .step-title { font-size: 14px; font-weight: 600; color: var(--foreground); margin-bottom: 6px; }
  .step-desc { font-size: 12.5px; color: var(--muted-foreground); line-height: 1.6; margin-bottom: 14px; }
  .code-block {
    background: oklch(0.18 0.02 280); border-radius: calc(var(--radius) + 2px);
    padding: 14px 16px; font-family: var(--font-mono, monospace); font-size: 11px; line-height: 1.8;
    border: 1px solid oklch(0.28 0.03 280);
  }
  .c-comment { color: #6B7280; }
  .c-cmd { color: #86EFAC; }
  .c-path { color: #FCD34D; }
  .c-str { color: #C4B5FD; }
  .c-out { color: oklch(0.82 0.12 304); }
  .c-prompt { color: #34D399; }

  /* ── Categories ── */
  .cats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 10px; }
  .cat-card { background: var(--card); border: 1px solid var(--border); border-radius: calc(var(--radius) + 4px); padding: 20px; transition: border-color 0.2s, transform 0.2s; }
  .cat-card:hover { border-color: color-mix(in oklch, var(--primary) 40%, transparent); transform: translateY(-2px); }
  .cat-icon { font-size: 20px; margin-bottom: 10px; }
  .cat-name { font-size: 13px; font-weight: 600; color: var(--foreground); margin-bottom: 3px; }
  .cat-count { font-size: 11px; color: var(--primary); font-family: var(--font-mono, monospace); margin-bottom: 7px; font-weight: 500; }
  .cat-ex { font-size: 11.5px; color: var(--muted-foreground); line-height: 1.5; }

  /* ── Price ── */
  .price-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: calc(var(--radius) + 8px);
    box-shadow: var(--shadow-lg);
    display: grid; grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }
  .price-left {
    padding: 48px 44px;
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column; justify-content: space-between;
  }
  .price-left-top {}
  .price-launch {
    display: inline-flex; align-items: center; gap: 6px;
    background: color-mix(in oklch, var(--primary) 10%, transparent);
    border: 1px solid color-mix(in oklch, var(--primary) 20%, transparent);
    border-radius: 100px; padding: 4px 12px; margin-bottom: 24px;
    font-size: 10px; font-weight: 600; color: var(--primary);
    font-family: var(--font-mono, monospace); letter-spacing: 0.08em; text-transform: uppercase;
  }
  .price-number {
    font-size: 80px; font-weight: 700; line-height: 1;
    color: var(--foreground); letter-spacing: -0.04em; margin-bottom: 6px;
  }
  .price-once {
    font-size: 13px; color: var(--muted-foreground); margin-bottom: 4px;
  }
  .price-per-skill {
    font-family: var(--font-mono, monospace); font-size: 11px;
    color: var(--primary); font-weight: 500;
  }
  .price-left-bottom { margin-top: 36px; }
  .btn-buy {
    display: block; width: 100%; text-align: center;
    background: var(--primary); color: var(--primary-foreground);
    font-size: 14px; font-weight: 700; padding: 14px 20px;
    border-radius: var(--radius); text-decoration: none;
    transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: var(--shadow-md);
  }
  .btn-buy:hover { opacity: 0.88; transform: translateY(-1px); box-shadow: var(--shadow-lg); }
  .buy-sub {
    margin-top: 10px; font-size: 11px; color: var(--muted-foreground);
    font-family: var(--font-mono, monospace); text-align: center;
  }
  .price-right { padding: 48px 44px; }
  .price-right-label {
    font-size: 11px; font-weight: 600; color: var(--muted-foreground);
    font-family: var(--font-mono, monospace); letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 20px;
  }
  .price-perks { list-style: none; }
  .price-perk {
    font-size: 13px; color: var(--foreground);
    padding: 11px 0; border-bottom: 1px solid var(--border);
    display: flex; align-items: flex-start; gap: 10px; line-height: 1.4;
  }
  .price-perk:last-child { border-bottom: none; }
  .perk-check { color: oklch(0.58 0.15 142); font-size: 13px; flex-shrink: 0; margin-top: 1px; }

  /* ── FAQ ── */
  .faqs { max-width: 640px; margin: 0 auto; }
  details { border-bottom: 1px solid var(--border); }
  details:first-of-type { border-top: 1px solid var(--border); }
  summary { list-style: none; cursor: pointer; padding: 20px 0; font-size: 14px; font-weight: 600; color: var(--foreground); display: flex; align-items: center; justify-content: space-between; transition: color 0.2s; user-select: none; }
  summary::-webkit-details-marker { display: none; }
  summary:hover { color: var(--primary); }
  .faq-icon { font-size: 18px; color: var(--muted-foreground); transition: transform 0.25s, color 0.2s; flex-shrink: 0; margin-left: 16px; font-family: var(--font-mono, monospace); }
  details[open] .faq-icon { transform: rotate(45deg); color: var(--primary); }
  .faq-body { padding: 0 0 20px; font-size: 13.5px; color: var(--muted-foreground); line-height: 1.72; max-width: 580px; }

  /* ── Final CTA ── */
  .final-cta { text-align: center; padding: 100px 32px; max-width: 680px; margin: 0 auto; }
  .final-h { font-size: clamp(32px, 5vw, 52px); font-weight: 700; line-height: 1.06; letter-spacing: -0.025em; color: var(--foreground); margin-bottom: 16px; }
  .final-h em { font-style: normal; color: var(--primary); }
  .final-sub { font-size: 16px; color: var(--muted-foreground); margin-bottom: 36px; line-height: 1.65; }

  /* ── Footer ── */
  footer { border-top: 1px solid var(--border); padding: 18px 32px; text-align: center; font-size: 12px; color: var(--muted-foreground); font-family: var(--font-mono, monospace); display: flex; align-items: center; justify-content: center; gap: 14px; }
  footer a { color: inherit; text-decoration: none; transition: color 0.2s; }
  footer a:hover { color: var(--foreground); }

  /* ── Reveal ── */
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: none; }
  .d1 { transition-delay: 0.1s; } .d2 { transition-delay: 0.2s; } .d3 { transition-delay: 0.3s; }

  @media (max-width: 680px) {
    .nav { padding: 12px 20px; }
    .nav-label { display: none; }
    .hero { padding: 52px 20px 44px; }
    .section { padding: 56px 20px; }
    .section-alt .inner { padding: 56px 20px; }
    .steps { grid-template-columns: 1fr; }
    .proof-bar { padding: 12px 20px; gap: 16px; }
    .proof-sep { display: none; }
    .final-cta { padding: 72px 20px; }
    footer { padding: 14px 20px; flex-direction: column; gap: 4px; }
    .price-card { grid-template-columns: 1fr; }
    .price-left { border-right: none; border-bottom: 1px solid var(--border); padding: 36px 24px; }
    .price-right { padding: 32px 24px; }
  }
</style>

<div class="page">

  {purchased && (
    <div class="success">
      ✓ ¡Listo! Revisá tu email, el link de descarga ya está en camino.
    </div>
  )}

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-right">
<a href={checkoutUrl} class="btn-nav">Conseguir el pack →</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge reveal">
      <span class="hero-badge-dot"></span>
      Precio de lanzamiento · $12
    </div>

    <h1 class="hero-h reveal d1">
      Convierte Claude en<br>
      tu <em>equipo completo.</em>
    </h1>

    <p class="hero-sub reveal d2">
      698 skills curados para founders, solopreneurs y equipos chicos.
      Marketing, ventas, contenido, finanzas y estrategia.
      Se instalan en 2 minutos con un solo pago.
    </p>

    <div class="hero-actions reveal d3">
      <a href={checkoutUrl} class="btn-primary">
        Conseguir los 698 skills
        <span class="price-tag">$12</span>
      </a>
      <a href="#skills" style="font-size:14px;color:var(--muted-foreground);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--foreground)'" onmouseout="this.style.color='var(--muted-foreground)'">
        Ver qué incluye ↓
      </a>
    </div>

    <div class="hero-trust reveal d3">
      <span class="trust-item"><span class="check">✓</span> Pago único</span>
      <span class="trust-item"><span class="check">✓</span> Descarga instantánea</span>
      <span class="trust-item"><span class="check">✓</span> Garantía 7 días</span>
    </div>
  </section>

  <hr class="div" />

  <!-- PROOF BAR -->
  <div class="proof-bar">
    <div class="proof-item"><strong>698</strong> skills curados</div>
    <span class="proof-sep">·</span>
    <div class="proof-item"><strong>8</strong> categorías de negocio</div>
    <span class="proof-sep">·</span>
    <div class="proof-item"><strong>$0.017</strong> por skill</div>
    <span class="proof-sep">·</span>
    <div class="proof-item"><strong>2 min</strong> de instalación</div>
    <span class="proof-sep">·</span>
    <div class="proof-item"><strong>7 días</strong> de garantía</div>
  </div>

  <!-- SKILL PREVIEWS -->
  <section class="section" id="skills">
    <p class="eyebrow">Lo que obtienes</p>
    <h2 class="section-h">Skills que hacen el <span>trabajo duro.</span></h2>

    <div class="skills-grid reveal">
      {[
        { cmd: "/email-sequence",       cat: "Marketing",    desc: "Genera una secuencia de emails completa: asuntos, CTAs y frecuencia calibrada para tu producto." },
        { cmd: "/competitive-analysis", cat: "Estrategia",   desc: "Análisis de competidores con FODA, posicionamiento y oportunidades concretas para diferenciarte." },
        { cmd: "/financial-model",      cat: "Finanzas",     desc: "Modelo financiero con proyecciones a 12 meses, unit economics y análisis de escenarios." },
        { cmd: "/content-calendar",     cat: "Contenido",    desc: "Calendario editorial con ideas, formatos y canales para 30 días. Sin bloqueo creativo." },
        { cmd: "/sales-proposal",       cat: "Ventas",       desc: "Propuestas adaptadas a la situación del cliente. Más cierres, menos idas y vueltas." },
        { cmd: "/sop-builder",          cat: "Operaciones",  desc: "SOPs con pasos, responsables y criterios de éxito. Listo para pasarle al equipo." },
        { cmd: "/linkedin-post",        cat: "Contenido",    desc: "Posts con apertura que engancha, estructura clara y CTA. Sin relleno." },
        { cmd: "/pricing-strategy",     cat: "Finanzas",     desc: "Estrategia de precios basada en valor: niveles, anclaje, psicología y optimización de margen." },
        { cmd: "/legal-review",         cat: "Legal",        desc: "Revisión de contratos en lenguaje simple: qué riesgos hay, qué cambiar y por qué." },
      ].map(s => (
        <div class="skill-card">
          <div class="skill-cmd">{s.cmd}</div>
          <p class="skill-desc">{s.desc}</p>
          <span class="skill-cat">{s.cat}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- INSTALL -->
  <div class="section-alt">
    <div class="inner">
      <p class="eyebrow">Instalación</p>
      <h2 class="section-h">Listo en <span>menos de 2 minutos.</span></h2>

      <div class="steps reveal">
        <div class="step">
          <div class="step-num">01</div>
          <div class="step-title">Paga y descarga el ZIP</div>
          <p class="step-desc">Polar envía el enlace de descarga a tu email al instante.</p>
          <div class="code-block">
            <div class="c-comment"># Contenido del ZIP</div>
            <div class="c-path">claude-agents-pack/</div>
            <div class="c-str">&nbsp;├── skills/</div>
            <div class="c-str">&nbsp;├── guide.html</div>
            <div class="c-str">&nbsp;└── business.html</div>
          </div>
        </div>

        <div class="step">
          <div class="step-num">02</div>
          <div class="step-title">Copia al directorio de Claude</div>
          <p class="step-desc">Un solo comando. Mac, Linux y Windows (WSL).</p>
          <div class="code-block">
            <div class="c-comment"># Global (todos los proyectos)</div>
            <div><span class="c-prompt">$</span> <span class="c-cmd">cp -r skills/ ~/.claude/skills/</span></div>
            <br/>
            <div class="c-comment"># Solo en este proyecto</div>
            <div><span class="c-prompt">$</span> <span class="c-cmd">cp -r skills/ .claude/skills/</span></div>
          </div>
        </div>

        <div class="step">
          <div class="step-num">03</div>
          <div class="step-title">Invoca el skill</div>
          <p class="step-desc">Claude lo detecta automáticamente o lo invocas directo.</p>
          <div class="code-block">
            <div><span class="c-prompt">&gt;</span> <span class="c-cmd">/email-sequence</span></div>
            <br/>
            <div class="c-out">Claude: ¿Cuál es tu producto</div>
            <div class="c-out">y quién es tu audiencia?</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CATEGORIES -->
  <section class="section">
    <p class="eyebrow">Categorías</p>
    <h2 class="section-h">8 áreas de negocio. <span>Un solo pack.</span></h2>

    <div class="cats-grid reveal">
      {[
        { icon: "📈", name: "Marketing y Crecimiento",    n: 30, ex: "Email sequences, SEO, ads, lead gen, brand voice" },
        { icon: "✍️",  name: "Creación de Contenido",     n: 31, ex: "Blog, LinkedIn, YouTube, copywriting, hooks virales" },
        { icon: "💼", name: "Ventas y CRM",               n: 17, ex: "Outreach, propuestas, upsells, customer success" },
        { icon: "💰", name: "Finanzas y Precios",         n: 14, ex: "Modelos financieros, facturas, unit economics" },
        { icon: "⚖️",  name: "Legal y Contratos",         n:  9, ex: "Revisión de contratos, GDPR, NDA, términos" },
        { icon: "⚙️",  name: "Operaciones y SOPs",        n: 10, ex: "SOPs, onboarding, retención, actas de reunión" },
        { icon: "🧭", name: "Estrategia y Planificación", n: 30, ex: "OKRs, market research, roadmaps, análisis FODA" },
        { icon: "🤖", name: "IA para Negocios",           n:  7, ex: "Prompt engineering, agentes, automatización" },
      ].map(c => (
        <div class="cat-card">
          <div class="cat-icon">{c.icon}</div>
          <div class="cat-name">{c.name}</div>
          <div class="cat-ex">{c.ex}</div>
        </div>
      ))}
    </div>

    <div style="margin-top:28px;padding:18px 22px;border:1px solid var(--border);border-radius:calc(var(--radius) + 4px);background:var(--card);display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
      <span style="font-size:11px;font-weight:600;color:var(--muted-foreground);font-family:var(--font-mono,monospace);letter-spacing:0.08em;text-transform:uppercase;flex-shrink:0;">También incluye</span>
      <p style="font-size:13px;color:var(--muted-foreground);line-height:1.5;margin:0;">
        550+ skills de desarrollo: Python, JavaScript, TypeScript, React, DevOps, bases de datos, seguridad, testing y más.
